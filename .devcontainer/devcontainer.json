{
  "name": "PHP 8.5 FPM + Nginx",
  "dockerComposeFile": "../docker-compose.nginx-postgres.yml",
  "service": "php",
  "workspaceFolder": "/var/www/html",
  "forwardPorts": [8080],
  "customizations": {
    "vscode": {
      "extensions": ["bmewburn.vscode-intelephense-client"],
      "settings": {
        "php.validate.executablePath": "/usr/local/bin/php"
      }
    }
  }
}
